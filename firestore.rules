rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Leads collection — allow read and write from any authenticated source
    // (the app uses Firebase Anonymous or API-key access, not Firebase Auth)
    // For production with admin panel only, restrict reads to authenticated sessions
    match /leads/{leadId} {
      // Allow creates from anyone (public inquiry form)
      allow create: if request.resource.data.keys().hasAll([
        'name', 'email', 'phone', 'eventType', 'eventDate',
        'guestCount', 'budget', 'location', 'status', 'createdAt'
      ]);

      // Allow reads and updates for now (admin dashboard — no auth layer yet)
      allow read, update: if true;

      // Disallow deletes entirely
      allow delete: if false;
    }

    // Connectivity test collection — allow full access for health checks
    match /_connectivity_test/{docId} {
      allow read, write, delete: if true;
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
